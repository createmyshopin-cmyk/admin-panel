# ─────────────────────────────────────────────────────────
# Admin Panel — Environment Variables Template
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────

# Backend API URL (your Railway deployment URL or localhost for dev)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase (for direct admin queries — optional if all goes through backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase (for admin auth / user verification)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Admin JWT Secret (must match ADMIN_JWT_SECRET in backend)
NEXTAUTH_SECRET=your_nextauth_secret
